# ==========================================
# 2. JavaCC Generated Files (Important!)
# ==========================================
# We only keep the original .jj files, and ignore auto-generated java files
# If you want to keep them, you can comment these lines out
*TokenManager.java
*Constants.java
ParseException.java
SimpleCharStream.java
Token.java

# ==========================================
# 3. Prolog Files Artifacts (For Family Knowledge Base)
# ==========================================
# Backup files often created by text editors
*~
*.bak
*.tmp

# ==========================================
# 4. OS & System Specific Files (General)
# ==========================================
# Windows thumbnail databases
Thumbs.db
ehthumbs.db
Desktop.ini

# Multimedia folder prevents Windows Explorer from customizing the folder
[Dd]esktop.ini

# Mac files
.DS_Store
.AppleDouble
.LSOverride

