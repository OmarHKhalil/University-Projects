# ==========================================
# 1. Java Runtime Environment & Binary Outputs
# ==========================================
# Directories for compiled class files and build outputs
bin/
build/
dist/

# Individual class files if generated outside the bin directory
*.class

# Log and error files
*.log

# ==========================================
# 2. JavaCC Auto-Generated Files (Crucial!)
# ==========================================
# These files are regenerated by JavaCC from the .jj source; no need to track them
*TokenManager.java
*Constants.java
ParseException.java
SimpleCharStream.java
Token.java

# Note: The original 'test.java' file containing your custom main method 
# is NOT ignored by this configuration and will be tracked normally.

# ==========================================
# 3. IDE Configurations (Eclipse & Others)
# ==========================================
# Local Eclipse metadata and settings directories
.metadata/
.settings/
.nb-gradle/

# Uncomment these if you want team members to import from scratch without local config conflicts:
# .project
# .classpath

# JetBrains IntelliJ, VS Code, and other editors metadata
.idea/
*.iml
.vscode/

# ==========================================
# 4. OS-Specific Temporary Files
# ==========================================
# Windows system files
Thumbs.db
ehthumbs.db
Desktop.ini

# macOS system files
.DS_Store
.AppleDouble
.LSOverride