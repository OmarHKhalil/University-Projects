@model mike2.Controllers.AdminDashboardViewModel
@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="container mt-4">
    <h2 class="mb-4">Admin Dashboard</h2>

    <div class="row">
        <div class="col-md-3 mb-3">
            <div class="card text-bg-primary">
                <div class="card-body">
                    <h5 class="card-title">Today's Bookings</h5>
                    <p class="card-text display-6">@Model.TodayBookings</p>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="card text-bg-success">
                <div class="card-body">
                    <h5 class="card-title">This Month's Bookings</h5>
                    <p class="card-text display-6">@Model.MonthBookings</p>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="card text-bg-info">
                <div class="card-body">
                    <h5 class="card-title">Total Users</h5>
                    <p class="card-text display-6">@Model.TotalUsers</p>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="card text-bg-secondary">
                <div class="card-body">
                    <h5 class="card-title">Active Users</h5>
                    <p class="card-text display-6">@Model.ActiveUsers</p>
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-3">
        <div class="col-md-6 mb-3">
            <div class="card text-bg-warning">
                <div class="card-body">
                    <h5 class="card-title">Total Reviews</h5>
                    <p class="card-text display-6">@Model.TotalReviews</p>
                </div>
            </div>
        </div>
        <div class="col-md-6 mb-3">
            <div class="card text-bg-dark">
                <div class="card-body">
                    <h5 class="card-title">Visible Reviews</h5>
                    <p class="card-text display-6">@Model.VisibleReviews</p>
                </div>
            </div>
        </div>
    </div>

    <hr />
    <div class="mt-3">
        <a asp-action="Users" class="btn btn-outline-primary me-2">Users Management</a>
        <a asp-action="Services" class="btn btn-outline-info me-2">Services & Categories</a>
        <a asp-action="Reviews" class="btn btn-outline-secondary me-2">Reviews Management</a>
        <a asp-action="Reports" class="btn btn-outline-success">System Reports</a>
    </div>
</div>


