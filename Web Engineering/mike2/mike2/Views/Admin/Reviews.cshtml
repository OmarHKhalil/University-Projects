@model IEnumerable<mike2.Models.Review>
@{
    ViewData["Title"] = "Reviews Management";
}

<div class="container mt-4">
    <h2 class="mb-3">Reviews Management</h2>
    <p class="text-muted">Review all ratings and hide abusive reviews.</p>

    <table class="table table-hover table-bordered mt-3">
        <thead class="table-light">
            <tr>
                <th>Id</th>
                <th>Customer</th>
                <th>Service Provider</th>
                <th>Rating</th>
                <th>Comment</th>
                <th>Created At</th>
                <th>Visible?</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var r in Model)
        {
            <tr>
                <td>@r.Id</td>
                <td>@r.Reviewer?.FullName (@r.Reviewer?.Email)</td>
                <td>@r.ServiceProvider?.ApplicationUser?.FullName</td>
                <td>@r.Rating / 5</td>
                <td>@r.Comment</td>
                <td>@r.CreatedAt.ToString("yyyy/MM/dd HH:mm")</td>
                <td>
                    @if (r.IsVisible)
                    {
                        <span class="badge bg-success">Visible</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Hidden</span>
                    }
                </td>
                <td>
                    <form asp-action="ToggleReviewVisibility" method="post" class="d-inline">
                        <input type="hidden" name="id" value="@r.Id" />
                        <button type="submit" class="btn btn-sm @(r.IsVisible ? "btn-warning" : "btn-success")">
                            @(r.IsVisible ? "Hide as abusive" : "Show again")
                        </button>
                    </form>
                </td>
            </tr>
        }
        </tbody>
    </table>

    <a asp-action="Index" class="btn btn-secondary mt-3">Back to Admin Dashboard</a>
</div>


