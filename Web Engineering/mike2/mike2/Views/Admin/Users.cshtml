@model IEnumerable<mike2.Models.ApplicationUser>
@{
    ViewData["Title"] = "Users Management";
}

<div class="container mt-4">
    <h2 class="mb-3">Users Management</h2>
    <p class="text-muted">Create, edit and activate/deactivate users.</p>

    <div class="mb-3">
        <a asp-action="CreateUser" class="btn btn-primary">Create New User</a>
    </div>

    <table class="table table-striped table-bordered mt-3">
        <thead class="table-light">
            <tr>
                <th>Full Name</th>
                <th>Email</th>
                <th>Location</th>
                <th>Role</th>
                <th>Active?</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var user in Model)
        {
            <tr>
                <td>@user.FullName</td>
                <td>@user.Email</td>
                <td>@user.Location</td>
                <td>@user.Role</td>
                <td>
                    @if (user.IsActive)
                    {
                        <span class="badge bg-success">Active</span>
                    }
                    else
                    {
                        <span class="badge bg-danger">Disabled</span>
                    }
                </td>
                <td>
                    <a asp-action="EditUser" asp-route-id="@user.Id" class="btn btn-sm btn-outline-secondary me-1">
                        Edit
                    </a>
                    <form asp-action="ToggleUserActive" method="post" class="d-inline">
                        <input type="hidden" name="id" value="@user.Id" />
                        <button type="submit" class="btn btn-sm @(user.IsActive ? "btn-danger" : "btn-success")">
                            @(user.IsActive ? "Disable" : "Activate")
                        </button>
                    </form>
                </td>
            </tr>
        }
        </tbody>
    </table>

    <a asp-action="Index" class="btn btn-secondary mt-3">Back to Admin Dashboard</a>
</div>


