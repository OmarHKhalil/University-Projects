@model mike2.Models.AppServiceProvider

@{
    ViewData["Title"] = "Manage Profile";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">
                        <i class="fas fa-user-edit"></i> Manage Profile
                    </h4>
                </div>

                <div class="card-body">
                    @if (TempData.ContainsKey("SuccessMessage"))
                    {
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            @TempData["SuccessMessage"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    <p class="text-muted mb-4">
                        Complete your profile information to help customers better understand you and your services.
                    </p>

                    <form asp-action="Profile" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-3">
                            <label asp-for="Experience" class="form-label fw-bold">
                                <i class="fas fa-briefcase"></i> Experience
                            </label>
                            <textarea asp-for="Experience"
                                    class="form-control"
                                    rows="4"
                                    placeholder="Tell customers about your experience: years of experience, companies you've worked for, important projects..."
                                    maxlength="1000"></textarea>
                            <div class="form-text">
                                Your professional story helps customers make informed decisions
                            </div>
                            <span asp-validation-for="Experience" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Specializations" class="form-label fw-bold">
                                <i class="fas fa-star"></i> Specializations
                            </label>
                            <textarea asp-for="Specializations"
                                    class="form-control"
                                    rows="3"
                                    placeholder="What are your areas of specialization? e.g.: Computer repair, web development, phone repairs..."
                                    maxlength="500"></textarea>
                            <div class="form-text">
                                Separate specializations with commas or new lines
                            </div>
                            <span asp-validation-for="Specializations" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="CoveredAreas" class="form-label fw-bold">
                                <i class="fas fa-map-marker-alt"></i> Covered Areas
                            </label>
                            <textarea asp-for="CoveredAreas"
                                    class="form-control"
                                    rows="3"
                                    placeholder="What areas do you serve? e.g.: Riyadh, Jeddah, Dammam..."
                                    maxlength="500"></textarea>
                            <div class="form-text">
                                Separate areas with commas or new lines
                            </div>
                            <span asp-validation-for="CoveredAreas" class="text-danger"></span>
                        </div>

                        <div class="d-flex gap-2 mt-4">
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-save"></i> Save Changes
                            </button>
                            <a asp-controller="Services" asp-action="Index" class="btn btn-outline-secondary">
                                <i class="fas fa-arrow-left"></i> Back to Services
                            </a>
                        </div>
                    </form>
                </div>

                <!-- Profile Preview Section -->
                <div class="card-footer bg-light">
                    <h6 class="fw-bold mb-3">
                        <i class="fas fa-eye"></i> Profile Preview
                    </h6>

                    <div class="border rounded p-3 mb-3">
                        <h6 class="text-primary">@Model.ApplicationUser?.FullName</h6>
                        <div class="star-rating mb-2">
                            @for (int i = 1; i <= 5; i++)
                            {
                                if (i <= Math.Floor(Model.Rating))
                                {
                                    <span class="text-warning">★</span>
                                }
                                else
                                {
                                    <span class="text-muted">☆</span>
                                }
                            }
                            <small class="ms-2">(@Model.Rating.ToString("F1"))</small>
                        </div>

                        @if (!string.IsNullOrEmpty(Model.Experience))
                        {
                            <p class="text-muted small mb-2">
                                <strong>Experience:</strong> @Model.Experience
                            </p>
                        }

                        @if (!string.IsNullOrEmpty(Model.Specializations))
                        {
                            <p class="text-muted small mb-2">
                                <strong>Specializations:</strong> @Model.Specializations
                            </p>
                        }

                        @if (!string.IsNullOrEmpty(Model.CoveredAreas))
                        {
                            <p class="text-muted small mb-2">
                                <strong>Covered Areas:</strong> @Model.CoveredAreas
                            </p>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
.star-rating {
    font-size: 16px;
}
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
