@model mike2.Models.Availability

@{
    ViewData["Title"] = "Delete Availability";
}

<h2>Delete Availability</h2>

<h4>Are you sure you want to delete this slot?</h4>

<div>
    <dl class="row">
        <dt class="col-sm-2">Date</dt>
        <dd class="col-sm-10">@Model.AvailableDate.ToString("yyyy-MM-dd")</dd>

        <dt class="col-sm-2">Start</dt>
        <dd class="col-sm-10">@Model.StartTime</dd>

        <dt class="col-sm-2">End</dt>
        <dd class="col-sm-10">@Model.EndTime</dd>
    </dl>
</div>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
