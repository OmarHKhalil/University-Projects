@model mike2.Models.Availability

@{
    ViewData["Title"] = "Availability Details";
}

<h2>Availability Details</h2>

<div>
    <dl class="row">
        <dt class="col-sm-2">Date</dt>
        <dd class="col-sm-10">@Model.AvailableDate.ToString("yyyy-MM-dd")</dd>

        <dt class="col-sm-2">Start</dt>
        <dd class="col-sm-10">@Model.StartTime</dd>

        <dt class="col-sm-2">End</dt>
        <dd class="col-sm-10">@Model.EndTime</dd>

        <dt class="col-sm-2">Booked?</dt>
        <dd class="col-sm-10">@((Model.IsBooked) ? "Yes" : "No")</dd>
    </dl>
</div>

<p>
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-secondary">Edit</a>
    <a asp-action="Index" class="btn btn-link">Back to list</a>
</p>
