@model IEnumerable<Availability>
@{
    ViewData["Title"] = "Manage Availability";
}

<h2>Manage Availability</h2>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">@TempData["SuccessMessage"]</div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
}

@if (TempData["DebugInfo"] != null)
{
    <div class="alert alert-info small">@TempData["DebugInfo"]</div>
}

<p>
    <a asp-action="Create" class="btn btn-primary">Add New Slot</a>
</p>

@if (!Model.Any())
{
    <div class="alert alert-info">
        No availability slots defined yet.
    </div>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Date</th>
                <th>Start</th>
                <th>End</th>
                <th>Booked?</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.AvailableDate.ToString("yyyy-MM-dd")</td>
                    <td>@item.StartTime</td>
                    <td>@item.EndTime</td>
                    <td>@(item.IsBooked ? "Yes" : "No")</td>
                    <td>
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Details</a>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-secondary">Edit</a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
