@model IEnumerable<mike2.Models.Booking>
@{
    ViewData["Title"] = "My Bookings";
}

<div class="container mt-4">
    <h2 class="mb-3">My Bookings</h2>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="mb-3">
        <a asp-action="CreateForCustomer" class="btn btn-primary">Book a Service</a>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info">You have no bookings yet.</div>
    }
    else
    {
        <table class="table table-striped table-bordered mt-3">
            <thead class="table-light">
                <tr>
                    <th>Service</th>
                    <th>Provider</th>
                    <th>Date</th>
                    <th>Time</th>
                    <th>Status</th>
                    <th>Cancel Reason</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var b in Model)
            {
                <tr>
                    <td>@b.Service?.Name</td>
                    <td>@b.ServiceProvider?.ApplicationUser?.FullName</td>
                    <td>@b.Availability?.AvailableDate.ToString("yyyy/MM/dd")</td>
                    <td>@b.Availability?.StartTime.ToString(@"hh\:mm") - @b.Availability?.EndTime.ToString(@"hh\:mm")</td>
                    <td>@b.Status</td>
                    <td>@b.CancelReason</td>
                    <td>
                        @if (b.Status == mike2.Models.BookingStatus.Pending || b.Status == mike2.Models.BookingStatus.Accepted)
                        {
                            <form asp-action="Cancel" method="post" class="d-inline">
                                <input type="hidden" name="id" value="@b.Id" />
                                <button type="submit" class="btn btn-sm btn-danger">
                                    Cancel
                                </button>
                            </form>
                        }
                        else if (b.Status == mike2.Models.BookingStatus.Completed && b.Review == null)
                        {
                            <a asp-action="CreateReview" asp-route-id="@b.Id" class="btn btn-sm btn-primary">
                                Leave Review
                            </a>
                        }
                        else if (b.Status == mike2.Models.BookingStatus.Completed && b.Review != null)
                        {
                            <span class="badge bg-success">Reviewed</span>
                        }
                    </td>
                </tr>
            }
            </tbody>
        </table>
    }
</div>
