@model IEnumerable<mike2.Models.Booking>

@{
    ViewData["Title"] = "Booking History";
}

<h2>Booking History</h2>

@if (!Model.Any())
{
    <div class="alert alert-info">
        No bookings yet.
    </div>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Booking #</th>
                <th>Customer</th>
                <th>Service</th>
                <th>Date</th>
                <th>Time</th>
                <th>Status</th>
                <th>Cancel / Reject Reason</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var b in Model)
            {
                <tr>
                    <td>@b.Id</td>
                    <td>@(b.Customer?.FullName ?? b.CustomerId)</td>
                    <td>@(b.Service?.Name ?? b.ServiceId.ToString())</td>
                    <td>@b.Availability?.AvailableDate.ToString("yyyy-MM-dd")</td>
                    <td>
                        @if (b.Availability != null)
                        {
                            @($"{b.Availability.StartTime:hh\\:mm} - {b.Availability.EndTime:hh\\:mm}")
                        }
                    </td>
                    <td>@b.Status</td>
                    <td>@b.CancelReason</td>
                    <td>
                        @if (b.Status == mike2.Models.BookingStatus.Accepted)
                        {
                            <form asp-controller="Bookings" asp-action="Complete" asp-route-id="@b.Id" method="post" style="display:inline">
                                <button type="submit" class="btn btn-primary btn-sm">Complete</button>
                            </form>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
