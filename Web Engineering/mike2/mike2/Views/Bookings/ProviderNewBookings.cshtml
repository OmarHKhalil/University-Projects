@model IEnumerable<mike2.Models.Booking>

@{
    ViewData["Title"] = "New Booking Requests";
}

<h2>New Booking Requests</h2>

@if (!Model.Any())
{
    <div class="alert alert-info">
        No new booking requests.
    </div>
}
else
{

    <p>
        <a asp-controller="Bookings"
           asp-action="ProviderBookingHistory"
           class="btn btn-outline-secondary btn-sm">
            Go to Booking History
        </a>
    </p>

    <table class="table table-striped">
        <thead>
            <tr>
                <th>Customer</th>
                <th>Service</th>
                <th>Date</th>
                <th>Time</th>
                <th>Status</th>
                <th>Cancel Reason</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var b in Model)
            {
                <tr>
                    <td>@(b.Customer?.FullName ?? b.CustomerId)</td>
                    <td>@(b.Service?.Name ?? b.ServiceId.ToString())</td>
                    <td>@b.Availability?.AvailableDate.ToString("yyyy-MM-dd")</td>

                    <td>
                        @if (b.Availability != null)
                        {
                            @($"{b.Availability.StartTime:hh\\:mm} - {b.Availability.EndTime:hh\\:mm}")
                        }
                    </td>

                    <td>@b.Status</td>
                    <td>@b.CancelReason</td>

                    <td>
                        <form asp-controller="Bookings" asp-action="Accept" asp-route-id="@b.Id" method="post" style="display:inline">
                            <button type="submit" class="btn btn-success btn-sm">Accept</button>
                        </form>

                        <form asp-controller="Bookings" asp-action="Reject" asp-route-id="@b.Id" method="post" style="display:inline">
                            <button type="submit" class="btn btn-danger btn-sm">Reject</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
