@model IEnumerable<mike2.Models.Notification>
@{
    ViewData["Title"] = "My Notifications";
}

<div class="container mt-4">
    <h2 class="mb-3">My Notifications</h2>

    <table class="table table-striped table-bordered mt-3">
        <thead class="table-light">
            <tr>
                <th>Booking</th>
                <th>Message</th>
                <th>Created At</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var n in Model)
        {
            <tr>
                <td>@n.BookingId</td>
                <td>@n.Message</td>
                <td>@n.CreatedAt.ToString("yyyy/MM/dd HH:mm")</td>
                <td>
                    @if (n.IsRead)
                    {
                        <span class="badge bg-secondary">Read</span>
                    }
                    else
                    {
                        <span class="badge bg-primary">New</span>
                    }
                </td>
                <td>
                    @if (!n.IsRead)
                    {
                        <form asp-action="MarkAsRead" method="post" class="d-inline">
                            <input type="hidden" name="id" value="@n.Id" />
                            <button type="submit" class="btn btn-sm btn-outline-success">Mark as read</button>
                        </form>
                    }

                    @if (n.BookingId.HasValue && User.IsInRole("ServiceProvider"))
                    {
                        var booking = n.Booking;
                        @if (booking != null && booking.Status == BookingStatus.Pending)
                        {
                            <form asp-controller="Bookings" asp-action="Accept" method="post" class="d-inline me-1">
                                <input type="hidden" name="id" value="@booking.Id" />
                                <button type="submit" class="btn btn-sm btn-success">Accept</button>
                            </form>
                            <form asp-controller="Bookings" asp-action="Reject" method="post" class="d-inline">
                                <input type="hidden" name="id" value="@booking.Id" />
                                <button type="submit" class="btn btn-sm btn-danger">Reject</button>
                            </form>
                        }
                        else if (booking != null)
                        {
                            <span class="badge bg-info">@booking.Status</span>
                        }
                    }

                    @if (n.BookingId.HasValue)
                    {
                        <a asp-controller="Bookings" asp-action="@(User.IsInRole("ServiceProvider") ? "ProviderBookings" : "MyBookings")" class="btn btn-sm btn-outline-primary ms-1">View Booking</a>
                    }
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>
