@model IEnumerable<mike2.Models.ApplicationUser>

<h2>Registered Users</h2>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Email</th>
            <th>Full Name</th>
            <th>Location</th>
            <th>Role</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var user in Model)
        {
            <tr>
                <td>@user.Email</td>
                <td>@user.FullName</td>
                <td>@user.Location</td>
                <td>@user.Role</td>
            </tr>
        }
    </tbody>
</table>
